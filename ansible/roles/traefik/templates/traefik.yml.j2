api:
  dashboard: true
  insecure: false

ping:
  entryPoint: traefik

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    address: ":443"
  traefik:
    address: ":8080"

certificatesResolvers:
  stepca:
    acme:
      email: "{{ certbot_email }}"
      storage: /certs/acme-internal.json
      caServer: "https://step-ca:9000/acme/acme/directory"
      httpChallenge:
        entryPoint: web

providers:
  file:
    directory: /config
    watch: true
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false

serversTransport:
  insecureSkipVerify: true

log:
  level: INFO
  filePath: /logs/traefik.log

accessLog:
  filePath: /logs/access.log
  fields:
    headers:
      names:
        User-Agent: keep
        X-Forwarded-For: keep

metrics:
  prometheus:
    addEntryPointsLabels: true
    addServicesLabels: true
    entryPoint: traefik
