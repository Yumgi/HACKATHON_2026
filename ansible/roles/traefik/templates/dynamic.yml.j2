http:
  routers:
    grafana:
      rule: "Host(`grafana.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: grafana
      tls: {}
      middlewares: [secure-headers]

    prometheus:
      rule: "Host(`prometheus.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: prometheus
      tls: {}
      middlewares: [basic-auth, secure-headers]

    loki:
      rule: "Host(`loki.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: loki
      tls: {}
      middlewares: [basic-auth, secure-headers]

    bareos:
      rule: "Host(`bareos.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: bareos
      tls: {}
      middlewares: [secure-headers]

    freeipa:
      rule: "Host(`ipa.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: freeipa
      tls: {}
      middlewares: [secure-headers]

    pfsense:
      rule: "Host(`pfsense.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: pfsense
      tls: {}
      middlewares: [secure-headers]

    traefik-dashboard:
      rule: "Host(`traefik.{{ domain_ext }}`)"
      entryPoints: [websecure]
      service: api@internal
      tls: {}
      middlewares: [basic-auth, secure-headers]

    intranet:
      rule: "Host(`intranet.{{ domain_lan }}`)"
      entryPoints: [websecure]
      service: grafana
      tls: {}
      middlewares: [secure-headers]

  services:
    grafana:
      loadBalancer:
        servers:
          - url: "http://{{ grafana_ip }}:3000"

    prometheus:
      loadBalancer:
        servers:
          - url: "http://{{ prometheus_ip }}:9090"

    loki:
      loadBalancer:
        servers:
          - url: "http://{{ loki_ip }}:3100"

    bareos:
      loadBalancer:
        servers:
          - url: "http://{{ bareos_ip }}:9100"

    freeipa:
      loadBalancer:
        servers:
          - url: "https://{{ freeipa_ip }}"
        passHostHeader: false

    pfsense:
      loadBalancer:
        servers:
          - url: "https://10.10.0.1"
        passHostHeader: false

  middlewares:
    basic-auth:
      basicAuth:
        usersFile: /opt/traefik/config/.htpasswd

    secure-headers:
      headers:
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        browserXssFilter: true
        contentTypeNosniff: true
        frameDeny: true

tls:
  certificates:
    - certFile: /opt/traefik/certs/wildcard.crt
      keyFile: /opt/traefik/certs/wildcard.key
  stores:
    default:
      defaultCertificate:
        certFile: /opt/traefik/certs/wildcard.crt
        keyFile: /opt/traefik/certs/wildcard.key
  options:
    default:
      minVersion: VersionTLS12
      cipherSuites:
        - TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384
        - TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256
        - TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305
