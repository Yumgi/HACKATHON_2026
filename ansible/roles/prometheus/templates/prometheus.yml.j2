global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    cluster: acme-corp
    env: production

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["localhost:9093"]

rule_files:
  - "/etc/prometheus/rules/*.yml"

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: node
    static_configs:
      - targets:
          - "{{ freeipa_ip }}:9100"
          - "{{ postgresql_ip }}:9100"
          - "{{ glpi_ip }}:9100"
          - "{{ prometheus_ip }}:9100"
          - "{{ grafana_ip }}:9100"
          - "{{ loki_ip }}:9100"
          - "{{ bareos_ip }}:9100"
          - "{{ traefik_ip }}:9100"

  - job_name: traefik
    static_configs:
      - targets: ["{{ traefik_ip }}:8080"]
    metrics_path: /metrics

  - job_name: postgresql
    static_configs:
      - targets: ["{{ postgresql_ip }}:9187"]

  - job_name: loki
    static_configs:
      - targets: ["{{ loki_ip }}:{{ loki_port }}"]
    metrics_path: /metrics

  - job_name: glpi
    static_configs:
      - targets: ["{{ glpi_ip }}:{{ glpi_port }}"]
    metrics_path: /metrics
