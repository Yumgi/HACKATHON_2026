#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 3 ]; then
  echo "Usage: $0 <client-name> <restore-path> <original-file>"
  echo "Example: $0 glpi-fd /tmp/bareos-restore /opt/restore-proof/proof.txt"
  exit 1
fi

CLIENT_NAME="$1"
RESTORE_PATH="$2"
ORIGINAL_FILE="$3"
TIMESTAMP="$(date '+%F %T')"
LOG_FILE="/var/log/bareos-restore-proof.log"

mkdir -p "$RESTORE_PATH"

cat <<EOF | bconsole
restore client=${CLIENT_NAME} select current all done where=${RESTORE_PATH} yes
quit
EOF

RESTORED_FILE="${RESTORE_PATH}${ORIGINAL_FILE}"

if [ -f "$RESTORED_FILE" ]; then
  echo "[${TIMESTAMP}] RESTORE OK - client=${CLIENT_NAME} file=${RESTORED_FILE}" | tee -a "$LOG_FILE"
  exit 0
else
  echo "[${TIMESTAMP}] RESTORE FAILED - client=${CLIENT_NAME} expected=${RESTORED_FILE}" | tee -a "$LOG_FILE"
  exit 1
fi
