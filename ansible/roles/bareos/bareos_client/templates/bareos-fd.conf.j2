Director {
  Name = {{ bareos_director_name }}
  Password = "{{ bareos_fd_password }}"
}

FileDaemon {
  Name = {{ inventory_hostname }}-fd
  FDport = 9102
  WorkingDirectory = "/var/lib/bareos"
  Pid Directory = "/run/bareos"
  Maximum Concurrent Jobs = 10
  Plugin Directory = "/usr/lib/bareos/plugins"
}

Messages {
  Name = Standard
  director = {{ bareos_director_name }} = all, !skipped, !restored
}
